# ─────────────────────────────────────────────────────────────────
# DNA Report Generator — Environment Variables
# Copy to .env and fill in your values before running Docker
# ─────────────────────────────────────────────────────────────────

# Flask
SECRET_KEY=replace-with-a-long-random-string-here
FLASK_ENV=production
PORT=5000

# PostgreSQL
POSTGRES_PASSWORD=change-me-in-production

# Redis (optional override — default uses docker-compose service name)
# REDIS_URL=redis://redis:6379/0

# Host port (what port nginx binds on the host machine)
HOST_PORT=80

# NCBI API Key (optional — raises rate limit from 3/sec to 10/sec)
# Get free key at: https://www.ncbi.nlm.nih.gov/account/
# NCBI_API_KEY=your_key_here
